<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.vpnhotspot">

    <uses-sdk android:minSdkVersion="21" android:targetSdkVersion="34" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:label="VPN热点开关"
        android:icon="@android:drawable/ic_menu_share"
        android:hasCode="true">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".StopActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <receiver
            android:name=".ProxyReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.vpnhotspot.SHOW" />
                <action android:name="com.vpnhotspot.HIDE" />
                <action android:name="com.vpnhotspot.TOGGLE" />
                <action android:name="com.vpnhotspot.TOGGGLE_START" />
                <action android:name="com.vpnhotspot.TOGGGLE_STOP" />
                <action android:name="com.vpnhotspot.STARTED" />
                <action android:name="com.vpnhotspot.STOPPED" />
                <action android:name="com.vpnhotspot.FAILED" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
